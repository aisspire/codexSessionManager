{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Session Manager",
  "identifier": "com.aisspire.codex-session-manager",
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Codex Session Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4RDdFQzIwODBERjVCMzcKUldRM1c5K0FJT3pYcURYVkJFT2lxOUhDZDB3K1dDRXdxRXJsUGZQQWtJb0RpOEVNUk1xNlRFb1MK",
      "endpoints": [
        "https://github.com/aisspire/codexSessionManager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}